# Copy this file to .env for development
# Copy to .env.production for Docker/production deployment

# ── Django Core ─────────────────────────────────────────────
SECRET_KEY=django-insecure-CHANGE-THIS-TO-A-LONG-RANDOM-STRING
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ─────────────────────────────────────────────────
# For development leave as sqlite (default)
# For production set DB_ENGINE=postgresql and fill remaining vars
DB_ENGINE=sqlite
DB_NAME=erms_db
DB_USER=erms_user
DB_PASSWORD=erms_securepassword
DB_HOST=localhost
DB_PORT=5432

# ── Email (SendGrid) ─────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# For production:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_HOST_USER=apikey
SENDGRID_API_KEY=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
DEFAULT_FROM_EMAIL=dev.theforge@gmail.com

# ── Twilio SMS ───────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
